# Native dev (no Docker). Leave POSTGRES_HOST unset to use SQLite.
DJANGO_SECRET_KEY=dev-insecure-secret-key-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Uncomment to use Postgres instead of SQLite:
# POSTGRES_DB=fitjourney
# POSTGRES_USER=fitjourney
# POSTGRES_PASSWORD=fitjourney
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
