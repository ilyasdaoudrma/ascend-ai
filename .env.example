# ---- Shared / Docker Compose ----
COMPOSE_PROJECT_NAME=fitjourney

# ---- PostgreSQL ----
POSTGRES_DB=fitjourney
POSTGRES_USER=fitjourney
POSTGRES_PASSWORD=fitjourney
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Django ----
DJANGO_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT lifetimes (minutes / days)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ---- Frontend ----
VITE_API_URL=http://localhost:8000/api/v1

# ============================================================
# PRODUCTION (set these on Render / Vercel — not used in local dev)
# ============================================================
# Backend (Render):
#   DJANGO_DEBUG=0
#   DJANGO_SECRET_KEY=<long-random-string>
#   DJANGO_ALLOWED_HOSTS=fitjourney-api.onrender.com
#   DATABASE_URL=postgresql://user:pass@host/db?sslmode=require   # from Neon
#   CLOUDINARY_URL=cloudinary://<key>:<secret>@<cloud-name>       # from Cloudinary
#   CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
#   CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app
#
# AI Coach chatbot (set ONE — Groq is free & fast; OpenAI also supported):
#   GROQ_API_KEY=gsk_...            # + optional GROQ_MODEL (default llama-3.3-70b-versatile)
#   OPENAI_API_KEY=sk-...           # + optional OPENAI_MODEL (default gpt-4o-mini)
#   (No key → the coach uses a built-in data-aware fallback.)
#
# Frontend (Vercel):
#   VITE_API_URL=https://fitjourney-api.onrender.com/api/v1
